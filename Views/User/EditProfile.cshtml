@{
    ViewData["Title"] = "Edytuj profil";
    var wydzialy = (SelectList)ViewData["Wydzialy"]!;
    var username = Context.Session.GetString("User");
}

<h1>Edytuj profil</h1>

<form method="post" asp-controller="User" asp-action="EditProfile" style="max-width: 400px">
    <div class="mb-3">
        <label class="form-label">Wydział</label>
        <select name="wydzialId" class="form-control" asp-items="wydzialy">
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Kierunek</label>
        <input type="text" name="kierunek" class="form-control" value="@ViewData["Kierunek"]" />
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a class="btn btn-outline-secondary ms-2" 
       asp-controller="User" 
       asp-action="Profile" 
       asp-route-username="@username">Anuluj</a>
</form>