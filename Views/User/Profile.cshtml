@using Microsoft.EntityFrameworkCore
@inject lab09.AppDbContext DbContext

@{
    ViewData["Title"] = "Profil użytkownika";
    var isOwner = Context.Session.GetString("User") == (ViewData["Username"] as string);
    var feed = ViewData["Posty"] as List<lab09.Post> ?? new List<lab09.Post>();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <h1 class="mb-0">@ViewData["Username"]</h1>
    <div class="border rounded px-3 py-2 bg-light">
        <small class="text-muted d-block">Wydział</small>
        <strong>@(string.IsNullOrEmpty((string?)ViewData["Wydzial"]) ? "nie podano" : ViewData["Wydzial"])</strong>
    </div>
    <div class="border rounded px-3 py-2 bg-light">
        <small class="text-muted d-block">Kierunek</small>
        <strong>@(string.IsNullOrEmpty((string?)ViewData["Kierunek"]) ? "nie podano" : ViewData["Kierunek"])</strong>
    </div>
    @if (isOwner)
    {
        <a class="btn btn-sm btn-outline-primary" asp-controller="User" asp-action="EditProfile">Edytuj profil</a>
    }
</div>

<hr />

<h3 class="mb-3">Posty</h3>
@foreach (var wpis in feed)
{
    var replies = DbContext?.PostReplies?.Where(r => r.PostId == wpis.Id).OrderBy(r => r.Id).ToList() ?? new List<lab09.PostReply>();
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="d-flex gap-2 align-items-center">
                    <a asp-controller="User" asp-action="Profile" asp-route-username="@wpis.Login?.LoginName">
                        <strong>@(wpis.Login?.LoginName ?? "(nieznany)")</strong>
                    </a>
                    @if (wpis.PostInfo?.Przedmiot != null)
                    {
                        <span class="badge bg-primary">@wpis.PostInfo.Przedmiot.Nazwa</span>
                    }
                    @if (wpis.PostInfo?.Prowadzacy != null)
                    {
                        <span class="badge bg-secondary">@wpis.PostInfo.Prowadzacy.Nazwa</span>
                    }
                    @if (wpis.PostInfo?.CzyPytanie == true)
                    {
                        <span class="badge bg-warning text-dark">Pytanie</span>
                    }                </div>
                <small class="text-muted">@wpis.PostInfo?.Data</small>
            </div>
            <p class="card-text mb-2">@wpis.Informacja</p>

            @if (replies.Any())
            {
                <div class="ms-3 border-start ps-3">
                    @foreach (var reply in replies)
                    {
                        <div class="mb-2">
                            <a asp-controller="User" asp-action="Profile" asp-route-username="@reply.Login?.LoginName">
                                <strong>@(reply.Login?.LoginName ?? "(nieznany)")</strong>
                            </a>
                            <small class="text-muted ms-2">@reply.Data</small>
                            <p class="mb-0">@reply.Tresc</p>
                        </div>
                    }
                </div>
            }

            <form asp-controller="Home" asp-action="AddReply" method="post" class="d-flex gap-2 mt-3">
                <input type="hidden" name="postId" value="@wpis.Id" />
                <input type="text" name="tresc" class="form-control form-control-sm" placeholder="Odpowiedz..." />
                <button type="submit" class="btn btn-sm btn-outline-primary">Wyślij</button>
            </form>
        </div>
    </div>
}