@{
    ViewData["Title"] = "Strona główna";
    var feed = (List<lab09.Post>)ViewData["Feed"]!;
}

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Wszystkie</a>
    <a class="btn btn-outline-warning btn-sm" asp-action="Index" asp-route-bezOdpowiedzi="true">Pytania bez odpowiedzi</a>
</div>

<form method="get" asp-action="Index" class="d-flex gap-2 mb-4">
    <input type="text" name="przedmiot" class="form-control form-control-sm"
           placeholder="Szukaj po przedmiocie..." value="@ViewData["Przedmiot"]" />
    <input type="text" name="prowadzacy" class="form-control form-control-sm"
           placeholder="Szukaj po prowadzącym..." value="@ViewData["Prowadzacy"]" />
    <button type="submit" class="btn btn-primary btn-sm">Szukaj</button>
</form>

<h2 class="mb-4">Ostatnie wpisy</h2>

@foreach (var wpis in feed.Where(w => w != null))
{
    var loginName = (wpis.Login != null) ? wpis.Login.LoginName : "Anonim";
    var replies = (wpis.Replies != null) ? wpis.Replies : new List<PostReply>();

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="d-flex gap-2 align-items-center">
                    @if (wpis.Login != null)
                    {
                        <a asp-controller="User" asp-action="Profile" asp-route-username="@loginName">
                            <strong>@loginName</strong>
                        </a>
                    }
                    else
                    {
                        <strong>@loginName</strong>
                    }
                    @if (wpis.PostInfo?.Przedmiot != null)
                    {
                        <span class="badge bg-primary">@wpis.PostInfo.Przedmiot.Nazwa</span>
                    }
                    @if (wpis.PostInfo?.Prowadzacy != null)
                    {
                        <span class="badge bg-secondary">@wpis.PostInfo.Prowadzacy.Nazwa</span>
                    }
                    @if (wpis.PostInfo?.CzyPytanie == true)
                    {
                        <span class="badge bg-warning text-dark">Pytanie</span>
                    }
                </div>
                <small class="text-muted">@wpis.PostInfo?.Data</small>
            </div>
            <p class="card-text mb-2">@wpis.Informacja</p>

            @if (replies.Any())
            {
                <div class="ms-3 border-start ps-3">
                    @foreach (var reply in replies)
                    {
                        @if (reply == null) continue;
                        <div class="mb-2">
                            @if (reply.Login != null)
                            {
                                <a asp-controller="User" asp-action="Profile" asp-route-username="@reply.Login.LoginName">
                                    <strong>@reply.Login.LoginName</strong>
                                </a>
                            }
                            else
                            {
                                <strong>Anonim</strong>
                            }
                            <small class="text-muted ms-2">@reply.Data</small>
                            <p class="mb-0">@(reply.Tresc ?? "Brak treści")</p>
                        </div>
                    }
                </div>
            }

            <form asp-controller="Home" asp-action="AddReply" method="post" class="d-flex gap-2 mt-3">
                <input type="hidden" name="postId" value="@wpis.Id" />
                <input type="text" name="tresc" class="form-control form-control-sm" placeholder="Odpowiedz..." />
                <button type="submit" class="btn btn-sm btn-outline-primary">Wyślij</button>
            </form>
        </div>
    </div>
}