@model List<string>

@{
    var przedmioty = ViewData["Przedmioty"] as List<lab09.Przedmiot> ?? new List<lab09.Przedmiot>();
    var prowadzacy = ViewData["Prowadzacy"] as List<lab09.Prowadzacy> ?? new List<lab09.Prowadzacy>();
    var error = ViewData["Error"] as string;
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}

<h2>Dodaj wpis</h2>

<form asp-action="AddData" method="post" style="max-width: 500px">
    <div class="mb-3">
        <label class="form-label">Treść</label>
        <input type="text" name="newData" class="form-control" placeholder="Wpisz treść..." required />
    </div>
    <div class="mb-3">
        <label class="form-label">Przedmiot</label>
        <select name="przedmiotId" class="form-control">
            <option value="">-- Wybierz przedmiot --</option>
            @foreach (var p in przedmioty)
            {
                <option value="@p.Id">@p.Nazwa</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Prowadzący</label>
        <select name="prowadzacyId" class="form-control">
            <option value="">-- Wybierz prowadzącego --</option>
            @foreach (var p in prowadzacy)
            {
                <option value="@p.Id">@p.Nazwa</option>
            }
        </select>
    </div>
    <div class="mb-3 form-check">
        <input type="checkbox" name="czyPytanie" class="form-check-input" value="true" />
        <label class="form-check-label">To jest pytanie</label>
    </div>
    <button type="submit" class="btn btn-primary">Dodaj</button>
</form>